#!/bin/sh
# xmux claude wrapper
#
# When running inside an xmux terminal (XMUX_RESOURCES_DIR is set):
#   - logs the normalized claude command line via the xmux CLI
#   - injects xmux lifecycle hooks via --settings
#
# Outside xmux, passes through to the real claude binary unchanged.
# Never breaks normal claude usage.

_self_dir="$(cd "$(dirname "$0")" 2>/dev/null && pwd)"

_quote_arg() {
    case "$1" in
        "")
            printf "''"
            ;;
        *[!A-Za-z0-9_./:=+-]*)
            printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"
            ;;
        *)
            printf '%s' "$1"
            ;;
    esac
}

# Locate the real claude binary — skip our own directory to avoid recursion.
_real_claude=""
_old_IFS="$IFS"
IFS=:
for _dir in $PATH; do
    [ -n "$_dir" ] || continue
    [ "$_dir" = "$_self_dir" ] && continue   # skip wrapper dir — no cd needed
    [ -x "$_dir/claude" ] || continue
    _real_claude="$_dir/claude"
    break
done
IFS="$_old_IFS"

if [ -z "$_real_claude" ]; then
    printf 'xmux: real claude binary not found in PATH\n' >&2
    exit 127
fi

# Not inside xmux — pass through unchanged.
if [ -z "$XMUX_RESOURCES_DIR" ]; then
    exec "$_real_claude" "$@"
fi

# Log the actual Claude command being launched.
_command="claude"
for _arg in "$@"; do
    _command="$_command $(_quote_arg "$_arg")"
done
_log_entry="$(printf 'claude.command\t%s' "$_command")"
command -v xmux >/dev/null 2>&1 && xmux log add "$_log_entry" >/dev/null 2>&1 || true

# Inject xmux lifecycle hooks via --settings.
_settings="${XMUX_RESOURCES_DIR}/claude-settings.json"
if [ -f "$_settings" ]; then
    exec "$_real_claude" --settings "$_settings" "$@"
else
    exec "$_real_claude" "$@"
fi
