{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [{"type": "command", "command": "\"$XMUX_CLAUDE_HOOK\" session-start"}]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [{"type": "command", "command": "\"$XMUX_CLAUDE_HOOK\" prompt-submit"}]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [{"type": "command", "command": "\"$XMUX_CLAUDE_HOOK\" pre-tool-use"}]
      }
    ],
    "Notification": [
      {
        "hooks": [{"type": "command", "command": "\"$XMUX_CLAUDE_HOOK\" notification"}]
      }
    ],
    "Stop": [
      {
        "hooks": [{"type": "command", "command": "\"$XMUX_CLAUDE_HOOK\" stop"}]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [{"type": "command", "command": "\"$XMUX_CLAUDE_HOOK\" session-end"}]
      }
    ]
  }
}
