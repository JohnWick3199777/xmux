# xmux zsh shell integration — command logger and helper command aliases.
# Sourced once per interactive session via the ZDOTDIR injection mechanism.

[[ -o interactive ]] || return 0

# Shell functions beat PATH order, so use them to ensure xmux wrappers win
# even if the user's shell config later rewrites PATH.
if [[ -n "${XMUX_RESOURCES_DIR:-}" ]]; then
    if [[ -x "${XMUX_RESOURCES_DIR}/bin/xpi" ]]; then
        xpi() {
            command "${XMUX_RESOURCES_DIR}/bin/xpi" "$@"
        }
    fi
    rehash 2>/dev/null || true
fi

# Logging hooks require the standalone xmux CLI.
(( $+commands[xmux] )) || return 0
(( ! $+functions[_xmux_preexec] )) || return 0  # already loaded

_xmux_preexec() {
    local cmd="$1"
    [[ -z "$cmd" ]] && return
    command xmux log add -- "$cmd" >/dev/null 2>&1 || true
    if [[ -n "${XMUX_TERMINAL_ID:-}" ]]; then
        command xmux event send --notify \
            --param "command=$cmd" \
            --param "terminal_id=$XMUX_TERMINAL_ID" \
            command.start >/dev/null 2>&1 || true
    else
        command xmux event send --notify \
            --param "command=$cmd" \
            command.start >/dev/null 2>&1 || true
    fi
}

typeset -ag preexec_functions
preexec_functions+=(_xmux_preexec)
